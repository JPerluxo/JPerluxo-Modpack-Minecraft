{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Setup: download packwiz",
      "type": "shell",
      "command": "powershell",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy", "Bypass",
        "-Command",
        "if (!(Test-Path packwiz.exe)) { Invoke-WebRequest -Uri https://nightly.link/packwiz/packwiz/workflows/go/main/Windows%2064-bit.zip -OutFile packwiz.zip; Expand-Archive packwiz.zip -DestinationPath . -Force; Remove-Item packwiz.zip } else { Write-Host 'packwiz already exists' }"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Packwiz: refresh",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": ["refresh"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Packwiz: add mod",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": [
        "modrinth",
        "add",
        "${input:modName}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Packwiz: remove mod",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": [
        "remove",
        "${input:modName}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "modName",
      "type": "promptString",
      "description": "Mod name"
    }
  ]
}
