{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Packwiz: refresh",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": ["refresh"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Packwiz: add mod",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": [
        "modrinth",
        "add",
        "${input:modName}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Packwiz: remove mod",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": [
        "remove",
        "${input:modName}"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "Packwiz: update mod",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": ["update", "${input:modName}"],
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      }
    },
    {
      "label": "Packwiz: generate .mrpack",
      "type": "shell",
      "command": "${workspaceFolder}/packwiz.exe",
      "args": ["modrinth", "export"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "modName",
      "type": "promptString",
      "description": "Mod name"
    }
  ]
}
